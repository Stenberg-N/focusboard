{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "focusboard",
  "version": "0.7.3",
  "identifier": "com.stenberg.focusboard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "FocusBoard",
        "width": 1700,
        "height": 1000,
        "minWidth": 1000,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNGRUM3QUZGQ0Y3ODRBQjAKUldTd1NualAvM3JzUDRpQzlKQWxrTkhCN1dYdGIrTjR5TmtpV0dzY0VDM1B2eGpwNlVzek96MHIK",
      "endpoints": [
        "https://github.com/Stenberg-N/focusboard/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "windows": {
        "installMode": "passive"
      }
    }
  } 
}
